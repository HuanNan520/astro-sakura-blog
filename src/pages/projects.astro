---
import Base from '../layouts/Base.astro';
import WalineComment from '../components/WalineComment.astro';
import { siteConfig } from '../config';
---
<Base title="Projects" description="Projects and works">
  <!-- Banner -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-primary-light/10 to-secondary/5 dark:from-primary/10 dark:via-primary-light/5 dark:to-secondary/10"></div>
    <div class="relative max-w-4xl mx-auto px-6 md:px-10 text-center">
      <h1 class="text-4xl md:text-5xl font-headline text-gray-800 dark:text-gray-100 mb-4">Projects</h1>
      <p class="text-lg text-muted dark:text-gray-400 max-w-2xl mx-auto">A showcase of things I've built, designed, or am currently working on.</p>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="max-w-5xl mx-auto px-6 md:px-10 py-16">
    {siteConfig.projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {siteConfig.projects.map((project) => (
          <a href={project.link} class="group bg-white dark:bg-card-dark rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col">
            {project.image && (
              <div class="w-full h-52 overflow-hidden bg-primary-light/10">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-3">
                {project.status && (
                  <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-[10px] rounded-full font-bold">
                    {project.status}
                  </span>
                )}
                {project.tech && (
                  <span class="px-2 py-0.5 bg-primary/5 dark:bg-primary-light/10 text-primary/70 dark:text-primary-light/70 text-[10px] rounded-full border border-primary/10 dark:border-primary-light/10">
                    {project.tech}
                  </span>
                )}
              </div>
              <h3 class="text-xl font-headline text-gray-800 dark:text-gray-100 mb-2 group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{project.title}</h3>
              <p class="text-sm text-muted dark:text-gray-400 leading-relaxed flex-1">{project.description}</p>
              <div class="mt-4 flex items-center gap-2">
                <span class="px-4 py-1.5 bg-gradient-to-r from-primary to-primary-light text-white rounded-xl text-xs group-hover:shadow-lg group-hover:shadow-primary/25 transition-all duration-500">View Details</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="text-6xl mb-4 opacity-30">
          <svg class="w-16 h-16 mx-auto text-primary/30 dark:text-primary-light/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
            <line x1="8" y1="21" x2="16" y2="21" />
            <line x1="12" y1="17" x2="12" y2="21" />
          </svg>
        </div>
        <h3 class="text-xl font-headline text-gray-600 dark:text-gray-400 mb-2">No projects yet</h3>
        <p class="text-sm text-muted dark:text-gray-500">Projects will appear here once added to the site configuration.</p>
      </div>
    )}
  </section>

  <!-- Comments -->
  {siteConfig.comments.serverURL && (
    <section class="max-w-3xl mx-auto px-6 md:px-10 pb-16">
      <WalineComment path="/projects/" />
    </section>
  )}
</Base>
