---
import Base from '../layouts/Base.astro';
---
<Base title="404 - Page Not Found">
  <section class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center">
    <!-- Large 404 -->
    <h1 class="text-[8rem] md:text-[12rem] font-headline font-bold bg-gradient-to-br from-primary via-primary-light to-secondary bg-clip-text text-transparent leading-none select-none">
      404
    </h1>

    <!-- Decorative stars -->
    <div class="flex items-center gap-3 my-4 text-primary-light dark:text-primary-light/60">
      <svg class="w-4 h-4 animate-pulse" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9" /></svg>
      <svg class="w-3 h-3 animate-pulse" style="animation-delay: 0.3s;" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9" /></svg>
      <svg class="w-5 h-5 animate-pulse" style="animation-delay: 0.6s;" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9" /></svg>
      <svg class="w-3 h-3 animate-pulse" style="animation-delay: 0.9s;" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9" /></svg>
      <svg class="w-4 h-4 animate-pulse" style="animation-delay: 1.2s;" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9" /></svg>
    </div>

    <!-- Message -->
    <p class="text-xl md:text-2xl font-headline text-gray-600 dark:text-gray-300 mb-2">
      Lost? There's nothing here.
    </p>
    <p class="text-sm text-muted/60 dark:text-gray-500 mb-10 max-w-md">
      The link may be broken or the page may have moved. No worries — click the button below to head back.
    </p>

    <!-- Back to Home -->
    <a
      href="/"
      class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-primary to-primary-light text-white rounded-full shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 font-headline text-sm"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
        <polyline points="9 22 9 12 15 12 15 22" />
      </svg>
      Back to Home
    </a>
    <a id="random-article-btn" href="/blog" class="px-6 py-3 bg-white/10 dark:bg-white/5 text-primary dark:text-primary-light rounded-2xl text-sm border border-primary/20 dark:border-primary-light/20 hover:bg-primary/10 transition-all mt-4">
      Random Article
    </a>
  </section>
  <script is:inline>
  fetch('/search.json').then(function(r){return r.json()}).then(function(posts){
    var btn = document.getElementById('random-article-btn');
    if(btn && posts.length){
      var random = posts[Math.floor(Math.random()*posts.length)];
      btn.href = '/blog/' + random.id + '/';
    }
  });
  </script>
</Base>
