---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import avatarImg from '../assets/images/avatar.png';
import { siteConfig } from '../config';
---
<Base title="About" description={`About ${siteConfig.author.name}`}>
  <section class="max-w-3xl mx-auto px-6 md:px-8 py-20">
    <!-- Header -->
    <div class="flex flex-col md:flex-row items-center gap-8 mb-16">
      <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-primary-light shadow-lg flex-shrink-0">
        <Image src={avatarImg} alt={siteConfig.author.name} class="w-full h-full object-cover" format="webp" />
      </div>
      <div>
        <h1 class="text-3xl md:text-4xl font-headline text-gray-800 dark:text-gray-100 mb-2">{siteConfig.author.name}</h1>
        <p class="text-lg text-muted dark:text-gray-400 font-headline italic">{siteConfig.author.tagline}</p>
      </div>
    </div>

    <div class="prose max-w-none">
      <!-- Bio -->
      <h2>About Me</h2>
      <p>{siteConfig.about.bio}</p>

      <!-- Skills -->
      {siteConfig.about.skills.length > 0 && (
        <>
          <h2>Skills & Tools</h2>
          <div class="flex flex-wrap gap-2 not-prose mb-8">
            {siteConfig.about.skills.map(skill => (
              <span class="text-[11px] px-3 py-1.5 bg-primary/5 dark:bg-primary-light/10 text-primary/70 dark:text-primary-light/70 rounded-full border border-primary/10 dark:border-primary-light/10">{skill}</span>
            ))}
          </div>
        </>
      )}

      <!-- Timeline -->
      {siteConfig.about.timeline.length > 0 && (
        <>
          <h2>Timeline</h2>
          <div class="not-prose space-y-3 mb-8">
            {siteConfig.about.timeline.map(entry => (
              <div class="flex items-start gap-3">
                <span class="text-xs text-muted/50 dark:text-gray-500 w-20 flex-shrink-0 pt-0.5">{entry.date}</span>
                <span class="text-sm text-gray-700 dark:text-gray-300">
                  {entry.event}
                  {entry.status && <span class="ml-2 text-xs text-primary dark:text-primary-light">({entry.status})</span>}
                </span>
              </div>
            ))}
          </div>
        </>
      )}

      <!-- Contact -->
      <h2>Contact</h2>
      <div class="flex flex-wrap gap-4 not-prose">
        {siteConfig.about.contact.email && (
          <a href={`mailto:${siteConfig.about.contact.email}`} class="inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-card-dark rounded-xl shadow-sm hover:shadow-md transition-all text-sm text-gray-700 dark:text-gray-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            {siteConfig.about.contact.email}
          </a>
        )}
        {siteConfig.about.contact.github && (
          <a href={`https://github.com/${siteConfig.about.contact.github}`} target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-card-dark rounded-xl shadow-sm hover:shadow-md transition-all text-sm text-gray-700 dark:text-gray-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {siteConfig.about.contact.github}
          </a>
        )}
      </div>
      {siteConfig.about.contact.extra && (
        <p class="text-sm text-gray-400 mt-4">{siteConfig.about.contact.extra}</p>
      )}
    </div>
  </section>
</Base>
