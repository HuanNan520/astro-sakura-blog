---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero.webp';
import avatarImg from '../assets/images/avatar.png';
import { siteConfig } from '../config';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];

const quotes = siteConfig.quotes.items;
const randomQuote = quotes.length > 0 ? quotes[Math.floor(Math.random() * quotes.length)] : '';

const dateLocale = siteConfig.language === 'en' ? 'en-US' : siteConfig.language === 'zh' ? 'zh-CN' : siteConfig.language === 'ja' ? 'ja-JP' : siteConfig.language;
---
<Base>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": siteConfig.name,
    "url": siteConfig.url,
    "description": siteConfig.description,
    "author": { "@type": "Person", "name": siteConfig.author.name }
  })} />
  <!-- Hero -->
  <section class="relative h-screen flex items-end overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Cover"
        class="w-full h-full object-cover !rounded-none hero-ken-burns"
        loading="eager"
        widths={[640, 1024, 1920]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/25 to-surface dark:to-surface-dark"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 pb-28 pt-32 flex flex-col md:flex-row gap-12 items-end w-full">
      <div class="flex-1">
        <span class="text-white/90 font-headline text-lg mb-4 block hero-fade-in hero-fade-delay-1" style="text-shadow: 0 2px 12px rgba(0,0,0,0.5);">
          {siteConfig.hero.subheading}
        </span>
        <h2 class="text-3xl sm:text-5xl md:text-7xl font-headline font-light text-white leading-tight tracking-tight max-w-3xl hero-fade-in hero-fade-delay-2" style="text-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 1px 4px rgba(0,0,0,0.3);" set:html={siteConfig.hero.heading}>
        </h2>
        <div class="mt-8 max-w-xl glass rounded-2xl p-6 border-l-2 border-primary-light hero-fade-in hero-fade-delay-3">
          <p class="text-gray-800 dark:text-gray-200 font-headline text-base md:text-lg italic leading-relaxed">
            {siteConfig.hero.description}
          </p>
        </div>
        <div class="mt-6 flex gap-3 hero-fade-in hero-fade-delay-4">
          <a href={siteConfig.hero.ctaPrimary.href} class="px-5 py-2.5 bg-gradient-to-r from-primary to-primary-light text-white rounded-xl text-sm hover:shadow-lg hover:shadow-primary/25 transition-all duration-300">{siteConfig.hero.ctaPrimary.text}</a>
          <a href={siteConfig.hero.ctaSecondary.href} class="px-5 py-2.5 bg-white/20 text-white rounded-xl text-sm backdrop-blur-sm hover:bg-white/30 transition-all duration-300">{siteConfig.hero.ctaSecondary.text}</a>
        </div>
      </div>
      <!-- Personal Card -->
      <div class="w-full md:w-72 glass p-6 rounded-3xl shadow-lg relative overflow-visible md:translate-y-10">
        <div class="absolute -top-12 right-4 w-24 h-24 rounded-full overflow-hidden border-4 border-white dark:border-card-dark shadow-lg bg-white">
          <Image src={avatarImg} alt={siteConfig.author.name} class="w-full h-full object-cover" format="webp" />
        </div>
        <div class="pt-8">
          <h3 class="font-headline text-xl text-primary dark:text-primary-light mb-1">{siteConfig.author.name}</h3>
          <p class="text-xs text-muted dark:text-gray-400 leading-relaxed">
            {siteConfig.author.tagline}
          </p>
          <!-- Stats -->
          <div class="mt-4 flex justify-around text-center border-t border-black/5 dark:border-white/5 pt-3 mb-3">
            <a href="/blog" class="group">
              <div class="text-lg font-bold text-primary dark:text-primary-light">{posts.length}</div>
              <div class="text-[10px] text-gray-400 group-hover:text-primary transition-colors">Posts</div>
            </a>
            <a href="/tags" class="group">
              <div class="text-lg font-bold text-primary dark:text-primary-light">{allTags.length}</div>
              <div class="text-[10px] text-gray-400 group-hover:text-primary transition-colors">Tags</div>
            </a>
            <a href="/projects" class="group">
              <div class="text-lg font-bold text-primary dark:text-primary-light">{siteConfig.projects.length}</div>
              <div class="text-[10px] text-gray-400 group-hover:text-primary transition-colors">Projects</div>
            </a>
          </div>
          <div class="flex gap-2">
            {siteConfig.nav.slice(0, 3).map(link => (
              <a href={link.href} class="flex-1 text-center text-[10px] px-2 py-1.5 bg-primary/10 dark:bg-primary-light/10 text-primary dark:text-primary-light rounded-full hover:bg-primary/20 transition-colors">{link.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Down Arrow -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 animate-float-arrow">
      <svg class="w-8 h-8 text-white/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </div>
  </section>

  <!-- Projects Showcase -->
  {siteConfig.projects.length > 0 && (
    <section class="bg-primary/[0.02] dark:bg-primary-light/[0.03] py-16">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
      <h3 class="text-2xl font-headline text-gray-800 dark:text-gray-100 mb-8">Projects</h3>
      <a href={siteConfig.projects[0].link} class="group bg-white dark:bg-card-dark rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-700 flex flex-col md:flex-row">
        {siteConfig.projects[0].image && (
          <div class="w-full md:w-[45%] h-48 md:h-80 overflow-hidden bg-primary-light/10">
            <img src={siteConfig.projects[0].image} alt={siteConfig.projects[0].title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" loading="lazy" />
          </div>
        )}
        <div class={`w-full ${siteConfig.projects[0].image ? 'md:w-[55%]' : ''} p-6 md:p-10 flex flex-col justify-center`}>
          <div class="flex items-center gap-2 mb-3">
            {siteConfig.projects[0].status && (
              <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-[10px] rounded-full font-bold">{siteConfig.projects[0].status}</span>
            )}
            {siteConfig.projects[0].tech && (
              <span class="px-2 py-0.5 bg-primary/5 dark:bg-primary-light/10 text-primary/70 dark:text-primary-light/70 text-[10px] rounded-full border border-primary/10 dark:border-primary-light/10">{siteConfig.projects[0].tech}</span>
            )}
          </div>
          <h4 class="text-2xl font-headline text-gray-800 dark:text-gray-100 mb-3 leading-snug">{siteConfig.projects[0].title}</h4>
          <p class="text-sm text-muted dark:text-gray-400 mb-6 leading-relaxed">
            {siteConfig.projects[0].description}
          </p>
          <div class="flex items-center gap-3">
            <span class="px-5 py-2 bg-gradient-to-r from-primary to-primary-light text-white rounded-xl text-xs group-hover:shadow-lg group-hover:shadow-primary/25 transition-all duration-500">View Details</span>
          </div>
        </div>
      </a>
      </div>
    </section>
  )}

<div class="flex items-center justify-center gap-4 py-6 max-w-7xl mx-auto px-6">
    <div class="h-px w-16 bg-gradient-to-r from-transparent to-primary/20"></div>
    <svg class="w-4 h-4 text-primary/15" viewBox="0 0 32 32" fill="currentColor"><g transform="translate(16,16)"><g opacity="0.85"><ellipse cx="0" cy="-8" rx="3.5" ry="7" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(72)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(144)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(216)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(288)" /></g></g></svg>
    <div class="h-px w-16 bg-gradient-to-l from-transparent to-primary/20"></div>
  </div>

    <!-- Main Content: Posts + Sidebar -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-16">
    <div class="flex flex-col md:flex-row gap-12">
      <!-- Left: Post List -->
      <div class="flex-1">
        <div class="flex items-center justify-between mb-8">
          <h3 class="text-2xl font-headline text-gray-800 dark:text-gray-100">Latest Posts</h3>
          <a href="/blog" class="text-primary dark:text-primary-light text-xs hover:underline">View All</a>
        </div>
        <div class="flex flex-col gap-6">
          {posts.slice(0, 6).map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class={`group post-card bg-white dark:bg-card-dark rounded-2xl overflow-hidden shadow-sm hover:shadow-xl flex flex-col ${i === 0 ? '' : 'md:flex-row'} animate-card-enter stagger-${(i % 6) + 1}`}
            >
              <div class={`${i === 0 ? 'w-full h-64' : 'md:w-2/5 h-48 md:h-auto'} overflow-hidden bg-primary-light/10`}>
                <img
                  src={post.data.cover?.src || `/images/covers/cover-${(i % 6) + 1}.webp`}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class={`${i === 0 ? 'w-full' : 'md:w-3/5'} p-5 md:p-6 flex flex-col justify-center`}>
                <div class="flex gap-2 mb-2 flex-wrap">
                  {post.data.tags?.map(tag => (
                    <span class="text-[10px] px-2.5 py-0.5 bg-primary/5 dark:bg-primary-light/10 text-primary/70 dark:text-primary-light/70 rounded-full border border-primary/10 dark:border-primary-light/10">
                      {tag}
                    </span>
                  ))}
                </div>
                <h4 class="text-base font-headline text-gray-800 dark:text-gray-100 mb-2 leading-snug group-hover:text-primary dark:group-hover:text-primary-light transition-colors duration-300">
                  {post.data.title}
                </h4>
                <p class="text-sm text-muted dark:text-gray-400 line-clamp-2 mb-3">{post.data.summary}</p>
                <div class="flex items-center gap-2 text-xs text-muted/50 dark:text-gray-500 font-body">
                  <span>{post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  <span>&middot;</span>
                  <span>~{Math.max(1, Math.ceil((post.body || '').replace(/\s+/g, '').length / 400))} min read</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Sidebar -->
      <aside class="w-full md:w-[280px] flex-shrink-0 flex flex-col gap-6">
        <!-- Author Card -->
        <div class="bg-white dark:bg-card-dark rounded-2xl p-6 shadow-sm text-center">
          <div class="relative w-20 h-20 mx-auto mb-3">
            <div class="absolute inset-0 rounded-full bg-gradient-to-br from-primary-light via-primary to-secondary opacity-40 blur-md scale-110"></div>
            <div class="relative w-20 h-20 rounded-full overflow-hidden border-[3px] border-white dark:border-primary-light/30 shadow-md">
              <Image src={avatarImg} alt={siteConfig.author.name} class="w-full h-full object-cover" format="webp" />
            </div>
          </div>
          <h4 class="font-headline text-lg text-gray-800 dark:text-gray-100">{siteConfig.author.name}</h4>
          <p class="text-xs text-muted dark:text-gray-400 mt-1">{siteConfig.author.motto}</p>
          <div class="flex justify-center gap-6 mt-4 text-center">
            <div>
              <span class="text-lg font-bold text-primary dark:text-primary-light">{posts.length}</span>
              <p class="text-[10px] text-muted dark:text-gray-500">Posts</p>
            </div>
            <div>
              <span class="text-lg font-bold text-primary dark:text-primary-light">{allTags.length}</span>
              <p class="text-[10px] text-muted dark:text-gray-500">Tags</p>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-black/5 dark:border-white/5">
            <p class="text-[11px] text-muted/60 dark:text-gray-500 italic font-headline">{siteConfig.author.motto}</p>
          </div>
        </div>

        <!-- Announcement -->
        <div class="bg-white dark:bg-card-dark rounded-2xl p-6 shadow-sm">
          <h4 class="font-headline text-sm text-gray-800 dark:text-gray-100 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-primary dark:text-primary-light" viewBox="0 0 24 24" fill="currentColor"><path d="M18 11v2h4v-2h-4zm-2 6.61c.96.71 2.21 1.65 3.2 2.39.4-.53.8-1.07 1.2-1.6-.99-.74-2.24-1.68-3.2-2.4-.4.54-.8 1.08-1.2 1.61zM20.4 5.6c-.4-.53-.8-1.07-1.2-1.6-.99.74-2.24 1.68-3.2 2.4.4.53.8 1.07 1.2 1.6.96-.72 2.21-1.65 3.2-2.4zM4 9c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2h1l5 3V6L5 9H4zm11.5 3c0-1.33-.58-2.53-1.5-3.35v6.69c.92-.81 1.5-2.01 1.5-3.34z"/></svg>
            Announcement
          </h4>
          <p class="text-xs text-muted dark:text-gray-400 leading-relaxed">
            {siteConfig.sidebar.announcement}
          </p>
        </div>

        <!-- Tag Cloud -->
        <div class="bg-white dark:bg-card-dark rounded-2xl p-6 shadow-sm">
          <h4 class="font-headline text-sm text-gray-800 dark:text-gray-100 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-primary dark:text-primary-light" viewBox="0 0 24 24" fill="currentColor"><path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/></svg>
            Tags
          </h4>
          <div class="flex flex-wrap gap-2">
            {allTags.map(tag => (
              <a href={`/tags#tag-${tag}`} class="text-[11px] px-3 py-1 bg-surface dark:bg-surface-dark text-muted dark:text-gray-400 rounded-full border border-black/5 dark:border-white/5 hover:bg-primary-light/20 hover:text-primary dark:hover:bg-primary/20 dark:hover:text-primary-light transition-all duration-300">
                {tag}
              </a>
            ))}
          </div>
        </div>

        <!-- Latest Posts List -->
        <div class="bg-white dark:bg-card-dark rounded-2xl p-6 shadow-sm">
          <h4 class="font-headline text-sm text-gray-800 dark:text-gray-100 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-primary dark:text-primary-light" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
            Latest Posts
          </h4>
          <div class="flex flex-col gap-3">
            {posts.slice(0, 5).map(post => (
              <a href={`/blog/${post.id}`} class="group flex items-center justify-between gap-3 py-2 border-b border-black/5 dark:border-white/5 last:border-0 hover:bg-primary/5 dark:hover:bg-primary-light/5 -mx-2 px-2 rounded-lg transition-colors duration-200">
                <span class="text-xs text-gray-700 dark:text-gray-300 group-hover:text-primary dark:group-hover:text-primary-light transition-colors truncate flex-1" style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
                  {post.data.title}
                </span>
                <span class="text-[10px] text-muted/40 dark:text-gray-600 flex-shrink-0">
                  {post.data.date.toLocaleDateString(dateLocale, { month: '2-digit', day: '2-digit' })}
                </span>
              </a>
            ))}
          </div>
        </div>

        <!-- Music Widget -->
        <div class="bg-white dark:bg-card-dark rounded-2xl p-6 shadow-sm relative overflow-hidden">
          <h4 class="font-headline text-sm text-gray-800 dark:text-gray-100 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-primary dark:text-primary-light" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
            Music
          </h4>
          <p class="text-xs text-gray-400 leading-relaxed">{siteConfig.sidebar.musicNote}</p>
        </div>
      </aside>
    </div>
  </section>

<div class="flex items-center justify-center gap-4 py-6 max-w-7xl mx-auto px-6">
    <div class="h-px w-16 bg-gradient-to-r from-transparent to-primary/20"></div>
    <svg class="w-4 h-4 text-primary/15" viewBox="0 0 32 32" fill="currentColor"><g transform="translate(16,16)"><g opacity="0.85"><ellipse cx="0" cy="-8" rx="3.5" ry="7" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(72)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(144)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(216)" /><ellipse cx="0" cy="-8" rx="3.5" ry="7" transform="rotate(288)" /></g></g></svg>
    <div class="h-px w-16 bg-gradient-to-l from-transparent to-primary/20"></div>
  </div>


  <!-- Quote -->
  {randomQuote && (
    <section class="max-w-4xl mx-auto px-6 md:px-10 py-20 text-center">
      <h5 class="text-3xl md:text-4xl font-headline font-light text-secondary/30 dark:text-secondary-light/20 leading-relaxed italic">
        "{randomQuote}"
      </h5>
      {siteConfig.quotes.source && (
        <div class="mt-6 flex justify-center items-center gap-4">
          <div class="h-px w-12 bg-border dark:bg-gray-700"></div>
          <span class="font-headline text-xs text-muted/50 dark:text-gray-600">{siteConfig.quotes.source}</span>
          <div class="h-px w-12 bg-border dark:bg-gray-700"></div>
        </div>
      )}
    </section>
  )}

  <div class="text-center pb-8">
    <a href="/about" class="text-sm text-muted/50 dark:text-gray-500 hover:text-primary dark:hover:text-primary-light transition-colors">Learn more about {siteConfig.author.name} &rarr;</a>
  </div>

</Base>
