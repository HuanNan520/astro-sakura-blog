---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero.webp';

const posts = (await getCollection('blog')).filter(p => !p.data.hidden).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const PAGE_SIZE = 8;

/* 计算每篇文章的预估阅读时间 */
function getReadingTime(body: string): number {
  const charCount = (body || '').replace(/\s+/g, '').length;
  return Math.max(1, Math.ceil(charCount / 400));
}

const seriesMap = new Map();
posts.forEach(p => {
  if (p.data.series) {
    if (!seriesMap.has(p.data.series)) seriesMap.set(p.data.series, []);
    seriesMap.get(p.data.series).push(p);
  }
});
const seriesList = [...seriesMap.entries()].filter(([, posts]) => posts.length >= 2);
---
<Base title="博客" description="All blog posts">
  <!-- 装饰 banner 背景 -->
  <div class="relative overflow-hidden h-64 md:h-72">
    <Image src={heroImg} alt="" class="absolute inset-0 w-full h-full object-cover !rounded-none blur-xl scale-110" aria-hidden="true" widths={[640, 1024]} sizes="100vw" />
    <div class="absolute inset-0 bg-surface/70 dark:bg-surface-dark/75"></div>
    <div class="relative z-10 flex flex-col justify-end h-full max-w-4xl mx-auto px-6 md:px-8 pb-10">
      <h1 class="text-3xl md:text-4xl font-headline text-gray-800 dark:text-gray-100 mb-2">博客</h1>
      <p class="text-muted dark:text-gray-400 text-sm">游戏策划笔记、开发日志、二次元碎碎念 · 共 {posts.length} 篇</p>
    </div>
  </div>

  {seriesList.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 md:px-8 pt-10">
      <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-none">
        {seriesList.map(([name, items]) => (
          <a href={`/blog/${items.sort((a,b) => (a.data.seriesOrder||0) - (b.data.seriesOrder||0))[0].id}`} class="flex-shrink-0 px-4 py-2 bg-white dark:bg-card-dark rounded-xl shadow-sm text-sm hover:shadow-md transition-all group">
            <span class="text-gray-800 dark:text-gray-100 font-headline group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{name}</span>
            <span class="text-[11px] text-muted/50 dark:text-gray-500 ml-2">{items.length} 篇</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-6 md:px-8 py-16">
    <div id="post-list" class="flex flex-col gap-8">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class={`group post-card bg-white dark:bg-card-dark rounded-2xl overflow-hidden shadow-sm hover:shadow-xl flex flex-col md:flex-row animate-card-enter stagger-${(i % 6) + 1}`}
          data-index={i}
          style={i >= PAGE_SIZE ? 'display:none' : ''}
        >
          <div class="md:w-1/3 h-52 md:h-auto overflow-hidden bg-primary-light/20">
            <img src={post.data.cover?.src || `/images/covers/cover-${(i % 6) + 1}.webp`} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="md:w-2/3 p-6 md:p-8 flex flex-col justify-center">
            <div class="flex gap-2 mb-3 flex-wrap">
              {post.data.tags?.map(tag => (
                <span class="text-[10px] px-2 py-1 bg-primary-light/30 dark:bg-primary/30 text-primary dark:text-primary-light rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-headline text-gray-800 dark:text-gray-100 mb-2 leading-snug group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{post.data.title}</h2>
            <p class="text-sm text-muted dark:text-gray-400 mb-4 line-clamp-2">{post.data.summary}</p>
            <div class="flex items-center gap-3 text-xs text-muted/50 dark:text-gray-500">
              <span>{post.data.date.toLocaleDateString('zh-CN')}</span>
              <span>&middot;</span>
              <span class="inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
                约 {getReadingTime(post.body || '')} 分钟
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* 加载更多 + 计数 */}
    {posts.length > PAGE_SIZE && (
      <div class="mt-12 text-center">
        <p id="post-count" class="text-xs text-muted/50 dark:text-gray-500 mb-4">显示 {PAGE_SIZE} / {posts.length} 篇</p>
        <button
          id="load-more-btn"
          class="px-8 py-3 bg-white dark:bg-card-dark rounded-xl text-sm text-gray-700 dark:text-gray-300 shadow-sm hover:shadow-md hover:text-primary dark:hover:text-primary-light transition-all cursor-pointer"
          data-total={posts.length}
          data-page-size={PAGE_SIZE}
        >
          加载更多
        </button>
      </div>
    )}
  </section>

  <script is:inline>
  (function() {
    function initLoadMore() {
      var btn = document.getElementById('load-more-btn');
      if (!btn || btn._bound) return;
      btn._bound = true;
      var total = parseInt(btn.dataset.total);
      var pageSize = parseInt(btn.dataset.pageSize);
      var shown = pageSize;
      var countEl = document.getElementById('post-count');
      var cards = document.querySelectorAll('#post-list > a[data-index]');

      function loadMore() {
        if (shown >= total) return;
        var next = Math.min(shown + pageSize, total);
        for (var i = shown; i < next; i++) {
          if (cards[i]) {
            cards[i].style.display = '';
            cards[i].classList.add('animate-card-enter');
          }
        }
        shown = next;
        if (countEl) countEl.textContent = '显示 ' + shown + ' / ' + total + ' 篇';
        if (shown >= total) {
          btn.style.display = 'none';
          if (countEl) countEl.textContent = '共 ' + total + ' 篇';
        }
      }

      btn.addEventListener('click', loadMore);

      /* 滚动到底部自动加载 */
      var scrollHandler = null;
      scrollHandler = function() {
        if (shown >= total) { window.removeEventListener('scroll', scrollHandler); return; }
        var rect = btn.getBoundingClientRect();
        if (rect.top < window.innerHeight + 200) {
          loadMore();
        }
      };
      window.addEventListener('scroll', scrollHandler, { passive: true });
    }
    initLoadMore();
    document.addEventListener('astro:page-load', initLoadMore);
  })();
  </script>
</Base>
