---
import { siteConfig } from '../config';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const iconMap: Record<string, string> = {
  home: '<path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>',
  projects: '<path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>',
  blog: '<path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>',
  about: '<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>',
};
---
<!-- 手机端底部导航（SVG图标，不依赖字体加载） -->
<nav class="md:hidden fixed bottom-0 w-full z-50 glass rounded-t-[2rem] shadow-2xl">
  <div class="flex justify-around items-center px-4 pb-[max(1.25rem,env(safe-area-inset-bottom,1.25rem))] pt-3">
    {siteConfig.nav.map(item => {
      const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
      const svgPath = iconMap[item.icon] || iconMap.home;
      return (
        <a
          href={item.href}
          class:list={[
            'flex flex-col items-center gap-1 py-2 px-3 transition-colors duration-300',
            isActive
              ? 'text-primary dark:text-primary-light'
              : 'text-gray-400 dark:text-gray-500 hover:text-primary dark:hover:text-primary-light',
          ]}
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><Fragment set:html={svgPath} /></svg>
          <span class="text-[10px]">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>
<button
  id="mobile-search-fab"
  class="md:hidden fixed bottom-[72px] left-1/2 -translate-x-1/2 z-50 w-10 h-10 rounded-full bg-primary/90 text-white shadow-lg flex items-center justify-center"
  aria-label="搜索"
>
  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
  </svg>
</button>
<script is:inline>
(function() {
  function initMobileSearchFab() {
    var fab = document.getElementById('mobile-search-fab');
    if (!fab || fab._bound) return;
    fab._bound = true;
    fab.addEventListener('click', function() {
      var searchToggle = document.getElementById('search-toggle');
      if (searchToggle) searchToggle.click();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  initMobileSearchFab();
  document.addEventListener('astro:page-load', initMobileSearchFab);
})();
</script>
